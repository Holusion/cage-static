 				output->wlr_output->name);
-			wlr_cursor_map_input_to_output(seat->cursor, input_device->device, output->wlr_output);
-	    wlr_cursor_map_input_to_region(seat->cursor, input_device->device, NULL);
+			wlr_cursor_map_input_to_output(seat->cage_cursor->cursor, input_device->device, output->wlr_output);
+	    wlr_cursor_map_input_to_region(seat->cage_cursor->cursor, input_device->device, NULL);
 			return;
 		}
 	}
