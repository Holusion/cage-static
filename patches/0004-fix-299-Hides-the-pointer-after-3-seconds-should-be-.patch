-	wlr_cursor_map_input_to_output(seat->cursor, input_device->device, NULL);
-	wlr_cursor_map_input_to_region(seat->cursor, input_device->device, &box);
+	wlr_cursor_map_input_to_output(seat->cage_cursor->cursor, input_device->device, NULL);
+	wlr_cursor_map_input_to_region(seat->cage_cursor->cursor, input_device->device, &box);
 }
 
 
@@ -194,8 +194,8 @@ static void handle_map_to_output(struct wl_client *client, struct wl_resource *r
