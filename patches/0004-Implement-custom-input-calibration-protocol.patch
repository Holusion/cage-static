+ */
+static inline void
+ext_input_calibration_manager_v1_send_add(struct wl_resource *resource_, struct wl_resource *id)
+{
+	wl_resource_post_event(resource_, EXT_INPUT_CALIBRATION_MANAGER_V1_ADD, id);
+}
+
